{
  "id": "umg-envoy-agent",
  "name": "UMG Envoy Agent",
  "version": "0.3.0-alpha.20",
  "description": "Runtime-facing UMG cognition specification and inspection plugin with ActionGate-bound runtime reports, ToolResult audit records, and a six-tool low-risk direct runner. It does not provide arbitrary dispatch, writes, deletes, or external transmission.",
  "entry": "dist/plugin-entry.js",
  "apiVersion": 1,
  "config": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "allowRuntimeWrites": {
        "type": "boolean",
        "description": "Keep runtime mutation disabled by default in the public package."
      },
      "contentMode": {
        "type": "string",
        "description": "Content loading mode for the public package."
      },
      "compilerMode": {
        "type": "string",
        "description": "Compiler adapter mode for the public package."
      },
      "compilerBridge": {
        "type": "object",
        "description": "Optional external compiler bridge configuration."
      },
      "relationMatrix": {
        "type": "object",
        "description": "Optional relation matrix emission configuration."
      },
      "debug": {
        "type": "boolean",
        "description": "Enable debug logging for the UMG runtime-facing cognition specification and inspection package."
      },
      "defaultSleeveId": {
        "type": "string",
        "description": "Optional default bundled public sleeve id."
      }
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "allowRuntimeWrites": {
        "type": "boolean",
        "default": false,
        "description": "Allow runtime write operations. Disabled by default for public release."
      },
      "contentMode": {
        "type": "string",
        "enum": ["bundled-public"],
        "default": "bundled-public",
        "description": "Use bundled public sample sleeves and blocks."
      },
      "compilerMode": {
        "type": "string",
        "enum": ["bundled-adapter", "external-cli"],
        "default": "bundled-adapter",
        "description": "Use the bundled public compiler adapter or the explicit external compiler bridge."
      },
      "compilerBridge": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "allowCompilerBridge": {
            "type": "boolean",
            "default": false,
            "description": "Explicitly allow external compiler bridge execution."
          },
          "compilerMode": {
            "type": "string",
            "enum": ["bundled-adapter", "external-cli"],
            "default": "bundled-adapter"
          },
          "compilerRepoPath": {
            "type": ["string", "null"],
            "default": null
          },
          "compilerCliPath": {
            "type": ["string", "null"],
            "default": null
          },
          "compilerCommand": {
            "type": ["string", "null"],
            "default": null
          },
          "compilerTimeoutMs": {
            "type": "number",
            "default": 30000
          },
          "compilerTempRoot": {
            "type": ["string", "null"],
            "default": null
          }
        }
      },
      "relationMatrix": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "allowRelationMatrixEmit": {
            "type": "boolean",
            "default": false
          },
          "relationMatrixMode": {
            "type": "string",
            "enum": ["response-only", "temp-write", "both"],
            "default": "response-only"
          },
          "relationMatrixTempRoot": {
            "type": ["string", "null"],
            "default": null
          },
          "relationMatrixWritePolicy": {
            "type": "string",
            "enum": ["temp-only"],
            "default": "temp-only"
          },
          "relationMatrixFormat": {
            "type": "string",
            "enum": ["umg-v0.1-ascii"],
            "default": "umg-v0.1-ascii"
          }
        }
      },
      "debug": {
        "type": "boolean",
        "default": false,
        "description": "Enable debug output."
      }
    }
  },
  "tools": [
    "umg_envoy_status",
    "umg_envoy_compiler_smoke_test",
    "umg_envoy_list_sleeves",
    "umg_envoy_load_sleeve",
    "umg_envoy_list_block_libraries",
    "umg_envoy_compile_sleeve",
    "umg_envoy_explain_sleeve",
    "umg_envoy_validate_runtime_output",
    "umg_envoy_compare_sleeves",
    "umg_envoy_parse_path",
    "umg_envoy_validate_path",
    "umg_envoy_render_path",
    "umg_envoy_build_path",
    "umg_envoy_matrix_status",
    "umg_envoy_cognitive_registry_query",
    "umg_envoy_plan_neostack",
    "umg_envoy_compose_sleeve_dry_run",
    "umg_envoy_validate_composed_sleeve_dry_run",
    "umg_envoy_compile_ir_bridge",
    "umg_envoy_emit_relation_matrix",
    "umg_envoy_action_gate_runtime_report_view",
    "umg_envoy_low_risk_direct_tool_run"
  ]
}
