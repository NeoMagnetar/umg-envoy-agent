{
  "id": "umg-envoy-agent",
  "name": "UMG Envoy Agent",
  "version": "0.3.0-alpha.3",
  "description": "Runtime-facing UMG cognition specification and inspection plugin for sleeves, RuntimeSpec projections, Trace artifacts, and library navigation inside OpenClaw.",
  "entry": "dist/plugin-entry-public.js",
  "apiVersion": 1,
  "config": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "allowRuntimeWrites": {
        "type": "boolean",
        "description": "Keep runtime mutation disabled by default in the public package."
      },
      "contentMode": {
        "type": "string",
        "description": "Content loading mode for the public package."
      },
      "compilerMode": {
        "type": "string",
        "description": "Compiler adapter mode for the public package."
      },
      "compilerBridge": {
        "type": "object",
        "description": "Optional external compiler bridge configuration."
      },
      "relationMatrix": {
        "type": "object",
        "description": "Optional relation matrix emission configuration."
      },
      "debug": {
        "type": "boolean",
        "description": "Enable debug logging for the UMG runtime-facing cognition specification and inspection package."
      },
      "defaultSleeveId": {
        "type": "string",
        "description": "Optional default bundled public sleeve id."
      }
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "allowRuntimeWrites": {
        "type": "boolean",
        "default": false,
        "description": "Allow runtime write operations. Disabled by default for public release."
      },
      "contentMode": {
        "type": "string",
        "enum": ["bundled-public"],
        "default": "bundled-public",
        "description": "Use bundled public sample sleeves and blocks."
      },
      "compilerMode": {
        "type": "string",
        "enum": ["bundled-adapter", "external-cli"],
        "default": "bundled-adapter",
        "description": "Use the bundled public compiler adapter or the explicit external compiler bridge."
      },
      "compilerBridge": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "allowCompilerBridge": {
            "type": "boolean",
            "default": false,
            "description": "Explicitly allow external compiler bridge execution."
          },
          "compilerMode": {
            "type": "string",
            "enum": ["bundled-adapter", "external-cli"],
            "default": "bundled-adapter"
          },
          "compilerRepoPath": {
            "type": ["string", "null"],
            "default": null
          },
          "compilerCliPath": {
            "type": ["string", "null"],
            "default": null
          },
          "compilerCommand": {
            "type": ["string", "null"],
            "default": null
          },
          "compilerTimeoutMs": {
            "type": "number",
            "default": 30000
          },
          "compilerTempRoot": {
            "type": ["string", "null"],
            "default": null
          }
        }
      },
      "relationMatrix": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "allowRelationMatrixEmit": {
            "type": "boolean",
            "default": false
          },
          "relationMatrixMode": {
            "type": "string",
            "enum": ["response-only", "temp-write", "both"],
            "default": "response-only"
          },
          "relationMatrixTempRoot": {
            "type": ["string", "null"],
            "default": null
          },
          "relationMatrixWritePolicy": {
            "type": "string",
            "enum": ["temp-only"],
            "default": "temp-only"
          },
          "relationMatrixFormat": {
            "type": "string",
            "enum": ["umg-v0.1-ascii"],
            "default": "umg-v0.1-ascii"
          }
        }
      },
      "debug": {
        "type": "boolean",
        "default": false,
        "description": "Enable debug output."
      }
    }
  },
  "tools": [
    "umg_envoy_status",
    "umg_envoy_library_status",
    "umg_envoy_library_search",
    "umg_envoy_runtime_spec_dry_run",
    "umg_envoy_runtime_visibility_header",
    "umg_envoy_runtime_molt_map",
    "umg_envoy_runtime_dashboard",
    "umg_envoy_runtime_ir_matrix",
    "umg_envoy_runtime_inspect",
    "umg_envoy_local_readonly_plan",
    "umg_envoy_local_readonly_scan",
    "umg_envoy_alpha_demo",
    "umg_envoy_sleeve_list",
    "umg_envoy_sleeve_inspect",
    "umg_envoy_sleeve_demo"
  ]
}
