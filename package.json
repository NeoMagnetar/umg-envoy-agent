{
  "name": "umg-envoy-agent",
  "version": "0.2.8",
  "description": "OpenClaw plugin for runtime-facing inspection and dry-run projection of governed UMG cognition artifacts.",
  "type": "module",
  "main": "dist/plugin-entry.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "public-content",
    "README.md",
    "PUBLIC-VARIANT-README.md",
    "PUBLIC-VARIANT-OVERVIEW.md",
    "openclaw.plugin.json",
    "package.json",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "smoke": "node dist/plugin-entry.js --smoke",
    "test:runtime-spec-boundary": "node dist/compiler/runtime-spec-boundary.test.js",
    "test:trace-boundary": "node dist/compiler/trace-boundary.test.js",
    "validate:umg:e2e": "node scripts/validate-umg-e2e.mjs",
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "umg",
    "universal-modular-generation",
    "openclaw",
    "plugin",
    "runtime-facing",
    "inspection",
    "dry-run",
    "runtimespec",
    "trace",
    "molt",
    "cognition-specification",
    "governed-artifacts",
    "sleeve-inspection",
    "diagnostics"
  ],
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./dist/plugin-entry.js"
    ],
    "compat": {
      "pluginApi": ">=1.2.0",
      "minGatewayVersion": "2026.3.23-1"
    },
    "install": {
      "minHostVersion": ">=2026.3.23"
    },
    "build": {
      "openclawVersion": "2026.3.23-1",
      "pluginSdkVersion": "2026.3.23-1"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
