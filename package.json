{
  "name": "umg-envoy-agent",
  "version": "0.1.2",
  "description": "UMG Envoy Agent is a modular cognitive runtime for OpenClaw that lets you parse, validate, render, and build human-inspectable planner paths through a bounded public-safe interface.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "README.md",
    "PUBLIC-VARIANT-README.md",
    "PUBLIC-VARIANT-OVERVIEW.md",
    "openclaw.plugin.json",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p ."
  },
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./dist/plugin-entry.js"
    ],
    "configSchema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultSleeveId": {
          "type": "string",
          "description": "Optional default public-safe sleeve id for build-path."
        }
      }
    },
    "compat": {
      "pluginApi": ">=2026.3.23-1",
      "minGatewayVersion": "2026.3.23-1"
    },
    "build": {
      "openclawVersion": "2026.3.23-1",
      "pluginSdkVersion": "2026.3.23-1"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
