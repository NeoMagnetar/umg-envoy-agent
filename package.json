{
  "name": "umg-envoy-agent",
  "version": "0.2.5",
  "description": "OpenClaw code plugin for loading, resolving, validating, and inspecting Universal Modular Generation workflows.",
  "type": "module",
  "main": "dist/plugin-entry.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "public-content",
    "README.md",
    "PUBLIC-VARIANT-README.md",
    "PUBLIC-VARIANT-OVERVIEW.md",
    "openclaw.plugin.json",
    "package.json",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "smoke": "node dist/plugin-entry.js --smoke",
    "validate:umg:e2e": "node scripts/validate-umg-e2e.mjs",
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "umg",
    "universal-modular-generation",
    "openclaw",
    "code-plugin",
    "ai-agent",
    "agent-framework",
    "modular-ai",
    "structured-generation",
    "workflow",
    "compiler-bridge",
    "canonical-ir",
    "relation-matrix",
    "runtime-spec",
    "diagnostics"
  ],
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./dist/plugin-entry.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.23-1",
      "minGatewayVersion": "2026.3.23-1"
    },
    "build": {
      "openclawVersion": "2026.3.23-1",
      "pluginSdkVersion": "2026.3.23-1"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
