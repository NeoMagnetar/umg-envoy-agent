{
  "name": "umg-envoy-agent",
  "version": "0.3.0-alpha.3",
  "description": "OpenClaw plugin for runtime-facing inspection and dry-run projection of governed UMG cognition artifacts.",
  "type": "module",
  "main": "dist/plugin-entry-public.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/plugin-entry-public.js",
    "dist/plugin-entry-public.d.ts",
    "dist/index.js",
    "dist/index.d.ts",
    "dist/types.js",
    "dist/types.d.ts",
    "dist/public-path-builder.js",
    "dist/public-path-builder.d.ts",
    "dist/umg-path-parser.js",
    "dist/umg-path-parser.d.ts",
    "dist/umg-path-renderer.js",
    "dist/umg-path-renderer.d.ts",
    "dist/umg-path-types.js",
    "dist/umg-path-types.d.ts",
    "dist/umg-path-validator.js",
    "dist/umg-path-validator.d.ts",
    "dist/resolver",
    "dist/runtime-spec",
    "dist/compiler/artifact-resolver.js",
    "dist/compiler/artifact-resolver.d.ts",
    "dist/compiler/canonical-ir-builder.js",
    "dist/compiler/canonical-ir-builder.d.ts",
    "dist/compiler/compiler-adapter.js",
    "dist/compiler/compiler-adapter.d.ts",
    "dist/compiler/compiler-matrix.js",
    "dist/compiler/compiler-matrix.d.ts",
    "dist/compiler/compiler-smoke.js",
    "dist/compiler/compiler-smoke.d.ts",
    "dist/compiler/content-loader.js",
    "dist/compiler/content-loader.d.ts",
    "dist/compiler/neostack-loader.js",
    "dist/compiler/neostack-loader.d.ts",
    "dist/compiler/neostack-validator.js",
    "dist/compiler/neostack-validator.d.ts",
    "dist/compiler/relation-matrix-format.js",
    "dist/compiler/relation-matrix-format.d.ts",
    "dist/compiler/relation-matrix-types.js",
    "dist/compiler/relation-matrix-types.d.ts",
    "dist/compiler/runtime-validator.js",
    "dist/compiler/runtime-validator.d.ts",
    "dist/compiler/sleeve-loader.js",
    "dist/compiler/sleeve-loader.d.ts",
    "dist/compiler/sleeve-schema-validator.js",
    "dist/compiler/sleeve-schema-validator.d.ts",
    "public-content",
    "README.md",
    "PUBLIC-VARIANT-README.md",
    "PUBLIC-VARIANT-OVERVIEW.md",
    "openclaw.plugin.json",
    "package.json",
    "tsconfig.json"
