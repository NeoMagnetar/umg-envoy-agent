  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "smoke": "node dist/plugin-entry.js --smoke",
    "umg:resolver:status": "node scripts/resolver-status.mjs",
    "umg:resolver:search": "node scripts/resolver-search.mjs",
    "umg:resolver:smoke": "node scripts/resolver-smoke.mjs",
    "umg:runtime-spec:smoke": "node scripts/runtime-spec-smoke.mjs",
    "umg:runtime-visibility:smoke": "node scripts/runtime-visibility-smoke.mjs",
    "umg:runtime-molt-map:smoke": "node scripts/runtime-molt-map-smoke.mjs",
    "umg:runtime-dashboard:smoke": "node scripts/runtime-dashboard-smoke.mjs",
    "umg:runtime-ir-matrix:smoke": "node scripts/runtime-ir-matrix-smoke.mjs",
    "umg:runtime-drilldown:smoke": "node scripts/runtime-drilldown-smoke.mjs",
    "umg:runtime-sleeve-selection:smoke": "node scripts/runtime-sleeve-selection-smoke.mjs",
    "umg:runtime-tool-binding:smoke": "node scripts/runtime-tool-binding-smoke.mjs",
    "umg:runtime-governed-handoff:smoke": "node scripts/runtime-governed-handoff-smoke.mjs",
    "umg:runtime-approval-checkpoint:smoke": "node scripts/runtime-approval-checkpoint-smoke.mjs",
    "umg:runtime-governed-alpha:smoke": "node scripts/runtime-governed-alpha-smoke.mjs",
    "umg:runtime-local-readonly-inspection:smoke": "node scripts/runtime-local-readonly-inspection-smoke.mjs",
    "umg:alpha-demo:smoke": "node scripts/alpha-demo-smoke.mjs",
    "umg:operational-sleeve:smoke": "node scripts/operational-sleeve-smoke.mjs",
    "umg:public-surface:smoke": "node scripts/public-surface-alignment-smoke.mjs",
    "validate:umg:e2e": "node scripts/validate-umg-e2e.mjs",
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "umg",
    "universal-modular-generation",
    "openclaw",
    "plugin",
    "runtime-facing",
    "inspection",
    "dry-run",
    "runtimespec",
    "trace",
    "molt",
    "cognition-specification",
    "governed-artifacts",
    "sleeve-inspection",
    "diagnostics"
  ],
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./dist/plugin-entry.js"
    ],
    "compat": {
      "pluginApi": ">=1.2.0",
      "minGatewayVersion": "2026.3.23-1"
    },
    "install": {
      "minHostVersion": ">=2026.3.23"
    },
    "build": {
      "openclawVersion": "2026.3.23-1",
      "pluginSdkVersion": "2026.3.23-1"
    }
  },
  "dependencies": {
    "@langchain/core": "^1.1.44",
    "@langchain/openai": "^1.4.5",
    "@sinclair/typebox": "^0.34.41",
    "langchain": "^1.3.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
