{
  "name": "umg-envoy-agent",
  "version": "0.3.0-alpha.14",
  "description": "OpenClaw plugin for bounded UMG runtime inspection, ActionGate capability control, ToolResult auditing, runtime report surfaces, and a six-tool low-risk direct runner with no arbitrary dispatch, writes, or external transmission.",
  "type": "module",
  "main": "dist/plugin-entry.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "public-content",
    "README.md",
    "PUBLIC-VARIANT-README.md",
    "PUBLIC-VARIANT-OVERVIEW.md",
    "openclaw.plugin.json",
    "package.json",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "smoke": "node dist/plugin-entry.js --smoke",
    "test:runtime-spec-boundary": "node dist/compiler/runtime-spec-boundary.test.js",
    "test:trace-boundary": "node dist/compiler/trace-boundary.test.js",
    "test:action-gate-types": "node dist/action-gate-types.test.js",
    "test:tool-capability-registry": "node dist/tool-capability-registry.test.js",
    "test:action-gate-preview-dry-run": "node dist/action-gate-preview-dry-run.test.js",
    "test:low-risk-allowlisted-tool-flow": "node dist/low-risk-allowlisted-tool-flow.test.js",
    "test:approval-gated-write-tool-flow": "node dist/approval-gated-write-tool-flow.test.js",
    "test:tool-result-audit-record": "node dist/tool-result-audit-record.test.js",
    "test:action-gate-runtime-report-surface": "node dist/action-gate-runtime-report-surface.test.js",
    "test:action-gate-runtime-report-tool-surface": "node dist/action-gate-runtime-report-tool-surface.test.js",
    "test:tool-capability-registry-seed": "node dist/tool-capability-registry-seed.test.js",
    "test:tool-manifest-alignment": "node dist/tool-manifest-alignment.test.js",
    "test:low-risk-direct-execution-adapter": "node dist/low-risk-direct-execution-adapter.test.js",
    "test:low-risk-direct-runtime-tool-surface": "node dist/low-risk-direct-runtime-tool-surface.test.js",
    "validate:umg:e2e": "node scripts/validate-umg-e2e.mjs",
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "umg",
    "openclaw",
    "envoy",
    "plugin",
    "actiongate",
    "tool-capability",
    "runtimespec",
    "trace",
    "toolresult",
    "modular-ai",
    "cognitive-runtime",
    "validation",
    "runtime-inspection",
    "low-risk-direct"
  ],
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./dist/plugin-entry.js"
    ],
    "compat": {
      "pluginApi": ">=1.2.0",
      "minGatewayVersion": "2026.3.23-1"
    },
    "install": {
      "minHostVersion": ">=2026.3.23"
    },
    "build": {
      "openclawVersion": "2026.3.23-1",
      "pluginSdkVersion": "2026.3.23-1"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
