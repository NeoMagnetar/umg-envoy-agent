{
  "$schema": "umg.resolver-rules.v1",
  "kind": "resolver_rule_set",
  "status": "public_safe_example",
  "notes": [
    "This is a public-safe example of the authored resolver rule architecture used by the private lane.",
    "It is intentionally limited and illustrative rather than a dump of private runtime rule content."
  ],
  "persistentStacks": [
    {
      "stackId": "stack.persona.core",
      "persistentBlockIds": [
        "block.persona.base",
        "block.persona.playful",
        "block.persona.analytical",
        "block.persona.formal"
      ],
      "alwaysActiveBlockIds": [
        "block.persona.base"
      ]
    },
    {
      "stackId": "stack.response.posture",
      "persistentBlockIds": [
        "block.posture.direct",
        "block.posture.expansive"
      ],
      "alwaysActiveBlockIds": []
    },
    {
      "stackId": "stack.response.format",
      "persistentBlockIds": [
        "block.format.list",
        "block.format.narrative"
      ],
      "alwaysActiveBlockIds": []
    }
  ],
  "cueGroups": [
    {
      "cueGroupId": "cuegroup.formal",
      "kind": "formal",
      "phrases": ["formal", "professional", "courteous"],
      "weight": 1
    },
    {
      "cueGroupId": "cuegroup.direct",
      "kind": "direct",
      "phrases": ["brief", "concise", "direct"],
      "weight": 1
    },
    {
      "cueGroupId": "cuegroup.list",
      "kind": "list",
      "phrases": ["bullet", "list", "checklist"],
      "weight": 1
    }
  ],
  "modulationRules": [
    {
      "ruleId": "rule.persona.formal",
      "family": "persona",
      "cueKind": "formal",
      "activateBlockId": "block.persona.formal",
      "suppressBlockIds": [
        "block.persona.playful",
        "block.persona.analytical"
      ],
      "compatibilityMode": "competing",
      "priority": 30
    },
    {
      "ruleId": "rule.posture.direct",
      "family": "posture",
      "cueKind": "direct",
      "activateBlockId": "block.posture.direct",
      "suppressBlockIds": [
        "block.posture.expansive"
      ],
      "compatibilityMode": "competing",
      "priority": 10
    },
    {
      "ruleId": "rule.format.list",
      "family": "format",
      "cueKind": "list",
      "activateBlockId": "block.format.list",
      "suppressBlockIds": [
        "block.format.narrative"
      ],
      "compatibilityMode": "competing",
      "priority": 10
    }
  ]
}
