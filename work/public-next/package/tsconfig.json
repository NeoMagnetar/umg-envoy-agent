{
    "compilerOptions":  {
                            "target":  "ES2022",
                            "module":  "NodeNext",
                            "moduleResolution":  "NodeNext",
                            "outDir":  "dist",
                            "rootDir":  "src",
                            "declaration":  true,
                            "esModuleInterop":  true,
                            "forceConsistentCasingInFileNames":  true,
                            "strict":  true,
                            "skipLibCheck":  true,
                            "resolveJsonModule":  true
                        },
    "include":  [
                    "src/index.ts",
                    "src/plugin-entry.ts",
                    "src/block-library-resolver.ts",
                    "src/public-path-builder.ts",
                    "src/types.ts",
                    "src/umg-path-parser.ts",
                    "src/umg-path-renderer.ts",
                    "src/umg-path-types.ts",
                    "src/umg-path-validator.ts",
                    "src/action-gate-policy-projection.ts",
                    "src/action-gate-approval-flow-projection.ts",
                    "src/action-gate-approval-checkpoint-projection.ts",
                    "src/action-gate-approval-decision-simulation.ts",
                    "src/controlled-action-dry-run-projection.ts",
                    "src/controlled-action-blocked-route-summary.ts",
                    "src/controlled-action-execution-readiness-matrix.ts",
                    "src/controlled-action-policy-readiness-integration.ts",
                    "src/controlled-action-policy-trace-report.ts",
                    "src/controlled-action-audit-packet.ts",
                    "src/controlled-action-audit-packet-export.ts",
                    "src/controlled-action-audit-packet-review-bundle.ts",
                    "src/controlled-action-review-decision-packet-projection.ts",
                    "src/controlled-action-review-decision-packet-recording-projection.ts",
                    "src/controlled-action-review-decision-packet-recording-audit-summary.ts",
                    "src/controlled-action-review-decision-packet-recording-review-export.ts",
                    "src/controlled-action-review-decision-packet-recording-handoff-bundle.ts",
                    "src/controlled-action-review-decision-packet-recording-phase-summary.ts",
                    "src/controlled-action-runtime-report-integration.ts",
                    "src/controlled-action-runtime-report-tool-surface.ts",
                    "src/compiler/**/*.ts"
                ]
}
