{
  "name": "umg-envoy-agent",
  "version": "0.3.0-alpha.12",
  "description": "Run Universal Modular Generation as a modular cognitive architectural runtime inside OpenClaw, with sleeve-aware orchestration, active sleeve session state, runtime inspection, IR Matrix visibility, and approved read-only tool gating.",
  "type": "module",
  "main": "dist/plugin-entry.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**",
    "README.md",
    "openclaw.plugin.json",
    "package.json",
    "docs",
    "fixtures",
    "schemas",
    "public-content"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "smoke": "node dist/plugin-entry.js --smoke",
    "pack:dry": "npm pack --dry-run",
    "validate:alpha-current": "node scripts/validate-alpha-current.mjs",
    "alpha6:real-library-resolver:smoke": "node scripts/alpha6-real-library-resolver-smoke.mjs",
    "alpha6:real-block-library-manifest-index:smoke": "node scripts/alpha6-real-block-library-manifest-index-smoke.mjs",
    "alpha6:real-block-library-manifest-entry-lookup:smoke": "node scripts/alpha6-real-block-library-manifest-entry-lookup-smoke.mjs",
    "alpha6:real-block-library-target-shallow-load-gate:smoke": "node scripts/alpha6-real-block-library-target-shallow-load-gate-smoke.mjs",
    "alpha6:real-block-library-target-shallow-load-single:smoke": "node scripts/alpha6-real-block-library-target-shallow-load-single-smoke.mjs",
    "alpha6:real-block-library-target-shallow-summary-normalization:smoke": "node scripts/alpha6-real-block-library-target-shallow-summary-normalization-smoke.mjs",
    "alpha6:real-block-library-neoblock-inspector:smoke": "node scripts/alpha6-real-block-library-neoblock-inspector-smoke.mjs",
    "alpha6:path-valid:smoke": "node scripts/alpha6-path-valid-smoke.mjs",
    "alpha6:path-invalid:smoke": "node scripts/alpha6-path-invalid-smoke.mjs",
    "alpha7:graph-resolver:smoke": "node scripts/alpha7-graph-resolver-smoke.mjs",
    "alpha7:sleeve-tree:smoke": "node scripts/alpha7-sleeve-tree-smoke.mjs",
    "alpha7:neostack-inspector:smoke": "node scripts/alpha7-neostack-inspector-smoke.mjs",
    "alpha7:neoblock-inspector:smoke": "node scripts/alpha7-neoblock-inspector-smoke.mjs",
    "alpha7:moltblock-inspector:smoke": "node scripts/alpha7-moltblock-inspector-smoke.mjs",
    "alpha7:runtime-ir-path:smoke": "node scripts/alpha7-runtime-ir-path-smoke.mjs",
    "alpha7:runtime-ir-matrix-full:smoke": "node scripts/alpha7-runtime-ir-matrix-full-smoke.mjs",
    "alpha7:response-envelope-draft:smoke": "node scripts/alpha7-response-envelope-draft-smoke.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./dist/plugin-entry.js"
    ],
    "runtimeExtensions": [
      "./dist/plugin-entry.js"
    ],
    "compat": {
      "pluginApi": ">=1.2.0",
      "minGatewayVersion": "2026.3.23-1"
    },
    "build": {
      "openclawVersion": "2026.3.23-1",
      "pluginSdkVersion": "2026.3.23-1"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.41"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
